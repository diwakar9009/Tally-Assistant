{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and basic information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "companyName": { "type": "string", "description": "Business name for reports" },
        "currency": { "type": "string", "description": "e.g., INR, USD" }
      },
      "required": ["uid", "email"]
    },
    "Ledger": {
      "title": "Ledger Account",
      "description": "A ledger account in the chart of accounts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "group": { "type": "string", "enum": ["Assets", "Liabilities", "Equity", "Revenue", "Expenses"], "description": "Primary account group" },
        "subGroup": { "type": "string", "description": "e.g., Bank Accounts, Cash-in-hand" },
        "openingBalance": { "type": "number" },
        "currentBalance": { "type": "number" },
        "createdBy": { "type": "string", "description": "User UID" }
      },
      "required": ["name", "group", "createdBy"]
    },
    "Voucher": {
      "title": "Accounting Voucher",
      "description": "A financial transaction record.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "voucherNumber": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["Payment", "Receipt", "Contra", "Journal", "Sales", "Purchase"] },
        "entries": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "ledgerId": { "type": "string" },
              "ledgerName": { "type": "string" },
              "amount": { "type": "number" },
              "entryType": { "type": "string", "enum": ["DR", "CR"] }
            }
          }
        },
        "narration": { "type": "string" },
        "totalAmount": { "type": "number" },
        "createdBy": { "type": "string" }
      },
      "required": ["date", "type", "entries", "createdBy"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User specific data and settings"
    },
    "/users/{uid}/ledgers/{ledgerId}": {
      "schema": "Ledger",
      "description": "The user's chart of accounts"
    },
    "/users/{uid}/vouchers/{voucherId}": {
      "schema": "Voucher",
      "description": "Accounting transactions"
    }
  }
}
